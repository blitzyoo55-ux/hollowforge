OAUTH2_PROXY_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=your-google-client-secret
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret
OAUTH2_PROXY_REDIRECT_URL=https://your-domain.example.com/oauth2/callback
# Optional: restrict sign-in to a domain (example.com). Default is *
OAUTH2_PROXY_EMAIL_DOMAIN=*
